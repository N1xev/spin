
package ui

import "charm.land/lipgloss/v2"

// Styles is the bundle of lipgloss v2 styles used by the TUI. Construct
// via NewStyles(width) on every WindowSizeMsg so width-dependent styles
// (wrapping, paddings) can re-flow.
type Styles struct {
	Title  lipgloss.Style
	Status lipgloss.Style
	Help   lipgloss.Style
}

// NewStyles returns a fresh Styles tuned for the given terminal width.
// Width is currently unused but the signature leaves room for width-
// dependent styles without churning callers when those land.
func NewStyles(width int) Styles {
	title := lipgloss.NewStyle().
		Bold(true).
		Foreground(lipgloss.Color("#FAFAFA")).
		Background(lipgloss.Color("#7D56F4")).
		Padding(0, 1)

	status := lipgloss.NewStyle().
		Foreground(lipgloss.Color("#FAFAFA")).
		Background(lipgloss.Color("#3C3836")).
		Padding(0, 1)

	help := lipgloss.NewStyle().
		Foreground(lipgloss.Color("#888888")).
		Italic(true)

	_ = width
	return Styles{Title: title, Status: status, Help: help}
}
