//
// Package app is the bubbletea v2 MVU model for the TUI. Update
// (update.go) and View (view.go) hold the per-message and per-frame
// logic; this file owns the Model struct + Init + Run.
//
// The `if has<Lib> .` blocks below gate every field on whether the
// corresponding charm library is enabled. Disabling a flag (e.g. by
// removing --huh from your flag set and re-scaffolding) drops the
// import + the wiring in one place.
package app

import (
{{- if hasBubbletea .}}
	"charm.land/bubbletea/v2"
{{- end}}
{{- if hasBubbles .}}
	"charm.land/bubbles/v2/spinner"
{{- end}}
{{- if hasLipgloss .}}
	"{{.Module}}/internal/ui"
{{- end}}
)

// Model is the bubbletea application state. Conditional fields
// (gated on the matching charm library) keep the struct minimal
// for projects that don't pull in every lib.
type Model struct {
{{- if hasBubbles .}}
	spinner spinner.Model
{{- end}}
{{- if hasLipgloss .}}
	styles ui.Styles
	width  int
{{- end}}
	count    int
	quitting bool
{{- if hasHarmonica .}}
	springPos float64
{{- end}}
{{- if hasHuh .}}
	name    string
	greeted bool
{{- end}}
{{- if hasGlamour .}}
	helpMarkdown string
{{- end}}
}

// New constructs a fresh Model with default values.
func New() *Model {
	return &Model{
{{- if hasBubbles .}}
		spinner: spinner.New(spinner.WithSpinner(spinner.Dot)),
{{- end}}
{{- if hasLipgloss .}}
		styles: ui.NewStyles(80),
{{- end}}
	}
}

// Init returns the bubbletea Cmd to run at startup. With --bubbles,
// we kick the spinner so it animates from the first frame; otherwise
// the program sits idle until a key is pressed.
func (m *Model) Init() tea.Cmd {
{{- if hasBubbles .}}
	return func() tea.Msg { return m.spinner.Tick() }
{{- else}}
	return nil
{{- end}}
}

// Run is the bubbletea program entry point. thin main.go calls this.
func Run() (tea.Model, error) {
	p := tea.NewProgram(New())
	return p.Run()
}
