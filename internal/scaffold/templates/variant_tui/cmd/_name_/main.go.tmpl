// Regenerate with: spin update {{.Name}}

// Thin entry point. All bubbletea model + update + view logic lives
// in internal/app/. This file just sets up logging (when --log) and
// hands control to app.Run().
package main

import (
{{- if not (hasLog .)}}
	"fmt"
{{- end}}
	"os"

{{- if hasLog .}}
	"charm.land/log/v2"
{{- end}}

	"{{.Module}}/internal/app"
)

func main() {
{{- if hasLog .}}
	logger := log.New(os.Stderr)
	log.SetDefault(logger)
	log.SetLevel(log.InfoLevel)
{{- end}}
	if _, err := app.Run(); err != nil {
{{- if hasLog .}}
		log.Error("program failed", "err", err)
{{- else}}
		fmt.Fprintln(os.Stderr, err)
{{- end}}
		os.Exit(1)
	}
}
