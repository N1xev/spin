// Regenerate with: spin update {{.Name}}

// Thin entry point. Both the TUI program (in internal/app/) and the
// CLI subcommands (in internal/cmd/) are exposed by fang.Execute on
// the root cobra command built in internal/cmd/root.go. The default
// behavior with no subcommand is to print help; explicit subcommands
// (hello, readme, ssh, tui) drive the rest of the surface.
package main

import (
	"context"
{{- if hasFang .}}
	"charm.land/fang/v2"
{{- end}}
{{- if not (hasLog .)}}
	"fmt"
{{- end}}
	"os"

{{- if hasLog .}}
	"charm.land/log/v2"
{{- end}}

	"{{.Module}}/internal/cmd"
)

func main() {
{{- if hasLog .}}
	logger := log.New(os.Stderr)
	log.SetDefault(logger)
	log.SetLevel(log.InfoLevel)
{{- end}}
	if err := fang.Execute(context.Background(), cmd.RootCmd(),
		fang.WithVersion("{{.SpinVer}}"),
	); err != nil {
{{- if hasLog .}}
		log.Error("command failed", "err", err)
{{- else}}
		fmt.Fprintln(os.Stderr, err)
{{- end}}
		os.Exit(1)
	}
}
