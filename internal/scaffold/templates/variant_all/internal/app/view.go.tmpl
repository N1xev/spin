//
// View composes the visible frame from Model. Conditional lipgloss
// styles, bubbles spinner, glamour help section, harmonica spring
// value, and huh-greeted banner are all inlined here — no separate
// lib/*.go file. The result is a single readable file that shows
// exactly how the libs compose.
package app

import (
	"fmt"

	"charm.land/bubbletea/v2"
)

// View returns the rendered frame. v2 bubbletea returns a tea.View
// value (not a string); AltScreen / MouseMode are fields on that
// value rather than program options as in v1.
func (m *Model) View() tea.View {
	if m.quitting {
		return tea.NewView("Bye!\n")
	}

{{- if hasBubbles .}}
	s := m.spinner.View()
{{- else}}
	s := ""
{{- end}}

	body := fmt.Sprintf("%s\nCount: %d\n\nPress up/down to change the count, q to quit.\n", s, m.count)
{{- if hasLipgloss .}}
	body = m.styles.Title.Render("{{title .Name}}") + "\n" + body
{{- else}}
	body = "{{title .Name}}\n" + body
{{- end}}

{{- if hasHuh .}}
	if m.greeted {
		body = body + fmt.Sprintf("\nGreeted: %s\n", m.name)
	}
{{- end}}
{{- if hasHarmonica .}}
	body = body + fmt.Sprintf("\nSpring: %.2f\n", m.springPos)
{{- end}}
{{- if hasGlamour .}}
	if m.helpMarkdown != "" {
		body = body + "\n" + m.helpMarkdown + "\n"
	}
{{- end}}

	return tea.NewView(body)
}
