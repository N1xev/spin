//
// Update handles every bubbletea message. The `if has<Lib> .` blocks
// inline the wiring for each charm library: huh forms launch from
// the 'n' keybinding, glamour renders the help markdown, harmonica
// advances the spring position, and bubbles ticks the spinner. No
// separate lib/*.go file is needed — all logic lives here so the
// scaffolded app reads like a real charmbracelet v2 example.
package app

import (
{{- if or (hasGlamour .) (hasHarmonica .) (hasLog .) (hasHuh .)}}
	"fmt"
	"os"
{{- end}}
{{- if hasHarmonica .}}
	"time"
{{- end}}
{{- if or (hasBubbletea .) (hasHarmonica .)}}
	"charm.land/bubbletea/v2"
{{- end}}
{{- if hasLipgloss .}}
	"{{.Module}}/internal/ui"
{{- end}}
{{- if hasBubbles .}}
	"charm.land/bubbles/v2/spinner"
{{- end}}
{{- if hasGlamour .}}
	"charm.land/glamour/v2"
{{- end}}
{{- if hasHarmonica .}}
	"github.com/charmbracelet/harmonica"
{{- end}}
{{- if hasHuh .}}
	"charm.land/huh/v2"
{{- end}}
{{- if hasLog .}}
	"charm.land/log/v2"
{{- end}}
)

{{ if hasHarmonica . -}}
// springTickMsg carries the harmonica spring position on each
// animation frame. Update pattern-matches on this type to advance
// the displayed counter.
type springTickMsg struct{ pos float64 }

func tickSpring() tea.Cmd {
	const fps = 60
	const target = 100.0
	spring := harmonica.NewSpring(harmonica.FPS(fps), 6.0, 0.5)
	pos, vel := 0.0, 0.0
	return tea.Tick(time.Second/fps, func(time.Time) tea.Msg {
		pos, vel = spring.Update(pos, vel, target)
		return springTickMsg{pos: pos}
	})
}
{{ end -}}

{{ if hasGlamour . -}}
// renderHelp produces a terminal-styled markdown string using glamour.
// Surfaces when the user presses 'g' in the TUI.
func renderHelp() (string, error) {
	r, err := glamour.NewTermRenderer(
		glamour.WithStandardStyle("dark"),
	)
	if err != nil {
		return "", err
	}
	return r.Render("## {{title .Name}}\n\nThis is `glamour` rendering markdown in your terminal.\n\n- Press `n` to fill a huh form\n- Press `s` to start the harmonica spring\n- Press `g` to re-render this help\n- Press `q` to quit\n")
}
{{ end -}}

// Update is the bubbletea message handler.
func (m *Model) Update(msg tea.Msg) (tea.Model, tea.Cmd) {
	switch msg := msg.(type) {
	case tea.KeyPressMsg:
		switch msg.String() {
		case "ctrl+c", "q", "esc":
			m.quitting = true
			return m, tea.Quit
		case "up", "k":
			m.count++
			return m, nil
		case "down", "j":
			m.count--
			return m, nil
{{- if hasHuh .}}
		case "n":
			// Inline huh form: a single text input, run synchronously,
			// updates m.name + m.greeted on completion. No lib/huh/huh.go
			// wrapper file needed — the form is right here in Update.
			var name string
			form := huh.NewForm(
				huh.NewGroup(
					huh.NewInput().
						Title("Your name?").
						Value(&name),
				),
			)
			_ = form.Run()
			m.name = name
			m.greeted = true
			return m, nil
{{- end}}
{{- if hasGlamour .}}
		case "g":
			if rendered, err := renderHelp(); err == nil {
				m.helpMarkdown = rendered
			} else {
				fmt.Fprintln(os.Stderr, err)
			}
			return m, nil
{{- end}}
{{- if hasHarmonica .}}
		case "s":
			m.springPos = 0
			return m, tickSpring()
{{- end}}
{{- if hasLog .}}
		case "l":
			log.Info("counter", "count", m.count)
			return m, nil
{{- end}}
		}
{{- if hasLipgloss .}}
	case tea.WindowSizeMsg:
		m.styles = ui.NewStyles(msg.Width)
		m.width = msg.Width
		return m, nil
{{- end}}
{{- if hasBubbles .}}
	case spinner.TickMsg:
		var cmd tea.Cmd
		m.spinner, cmd = m.spinner.Update(msg)
		return m, cmd
{{- end}}
{{- if hasHarmonica .}}
	case springTickMsg:
		m.springPos = msg.pos
		return m, tickSpring()
{{- end}}
	}
	return m, nil
}
