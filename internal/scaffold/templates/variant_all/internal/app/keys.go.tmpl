//
// KeyMap is the bubbletea v2 help.Component keybinding set. The base
// keys (up/down/quit/help) are always wired; the conditional ones
// (gated on `if has<Lib> .`) only appear when the corresponding charm
// library is enabled. This is the standard pattern for help.Component: a
// KeyMap struct with bindings.Binding fields + ShortHelp / FullHelp
// methods that return slices of bindings for the help view.
package app

import (
	"charm.land/bubbles/v2/key"
)

// KeyMap is the help.Component keybinding set. Each binding is
// exported so users of the app can inspect / rebind them.
type KeyMap struct {
	Up    key.Binding
	Down  key.Binding
	Quit  key.Binding
	Help  key.Binding
{{- if hasHuh .}}
	Name key.Binding
{{- end}}
{{- if hasGlamour .}}
	Glamour key.Binding
{{- end}}
{{- if hasHarmonica .}}
	Spring key.Binding
{{- end}}
{{- if hasLog .}}
	Log key.Binding
{{- end}}
}

// DefaultKeyMap returns a KeyMap with the conventional bindings:
// up/k to increment, down/j to decrement, q/ctrl+c to quit, ? for
// help, plus the conditional ones for huh / glamour / harmonica / log.
func DefaultKeyMap() KeyMap {
	return KeyMap{
		Up: key.NewBinding(
			key.WithKeys("up", "k"),
			key.WithHelp("↑/k", "count up"),
		),
		Down: key.NewBinding(
			key.WithKeys("down", "j"),
			key.WithHelp("↓/j", "count down"),
		),
		Quit: key.NewBinding(
			key.WithKeys("q", "ctrl+c", "esc"),
			key.WithHelp("q", "quit"),
		),
		Help: key.NewBinding(
			key.WithKeys("?"),
			key.WithHelp("?", "help"),
		),
{{- if hasHuh .}}
		Name: key.NewBinding(
			key.WithKeys("n"),
			key.WithHelp("n", "fill huh form"),
		),
{{- end}}
{{- if hasGlamour .}}
		Glamour: key.NewBinding(
			key.WithKeys("g"),
			key.WithHelp("g", "render help"),
		),
{{- end}}
{{- if hasHarmonica .}}
		Spring: key.NewBinding(
			key.WithKeys("s"),
			key.WithHelp("s", "spring"),
		),
{{- end}}
{{- if hasLog .}}
		Log: key.NewBinding(
			key.WithKeys("l"),
			key.WithHelp("l", "log count"),
		),
{{- end}}
	}
}

// ShortHelp returns the bindings shown in the condensed help view
// (the bottom row of the TUI). The base set is always present; the
// conditional bindings are appended when their lib is enabled.
func (k KeyMap) ShortHelp() []key.Binding {
	return []key.Binding{k.Up, k.Down,
{{- if hasHuh .}}
		k.Name,
{{- end}}
{{- if hasGlamour .}}
		k.Glamour,
{{- end}}
{{- if hasHarmonica .}}
		k.Spring,
{{- end}}
{{- if hasLog .}}
		k.Log,
{{- end}}
		k.Quit, k.Help}
}

// FullHelp returns the bindings grouped for the full help view
// (the ? key overlay). Each []key.Binding is one column.
func (k KeyMap) FullHelp() [][]key.Binding {
	return [][]key.Binding{
		{k.Up, k.Down},
{{- if or (hasHuh .) (hasGlamour .) (hasHarmonica .) (hasLog .)}}
		{
{{- if hasHuh .}}
			k.Name,
{{- end}}
{{- if hasGlamour .}}
			k.Glamour,
{{- end}}
{{- if hasHarmonica .}}
			k.Spring,
{{- end}}
{{- if hasLog .}}
			k.Log,
{{- end}}
		},
{{- end}}
		{k.Quit, k.Help},
	}
}
