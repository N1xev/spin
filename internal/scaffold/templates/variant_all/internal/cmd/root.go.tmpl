
package cmd

import (
{{- if hasCobra .}}
	"github.com/spf13/cobra"
{{- end}}
{{- if hasViper .}}
	"{{.Module}}/internal/config"
{{- end}}
)

// RootCmd builds and returns the root cobra command. The hello
// subcommand is always present; tui is added when --bubbletea;
// ssh is added when --wish. viper is wired via PersistentPreRunE
// when --viper is set.
func RootCmd() *cobra.Command {
	root := &cobra.Command{
		Use:   "{{.Name}}",
		Short: "A {{title .Name}} TUI + CLI combo scaffolded with spin",
		Long: `{{title .Name}} combines a charmbracelet v2 TUI with a cobra CLI in a
single binary. Run '{{.Name}} tui' to launch the TUI, '{{.Name}} hello
[name]' for a CLI greeting, or '{{.Name}} --help' for the full command
list.`,
{{- if hasViper .}}
		PersistentPreRunE: func(cmd *cobra.Command, args []string) error {
			return config.Bind(cmd.Root())
		},
{{- end}}
		SilenceUsage: true,
	}

	root.AddCommand(helloCmd)
{{- if hasBubbletea .}}
	root.AddCommand(tuiCmd)
{{- end}}
{{- if hasWish .}}
	root.AddCommand(sshCmd)
{{- end}}
{{- if hasViper .}}
	root.PersistentFlags().String("log-level", "info", "log level (debug, info, warn, error)")
{{- end}}

	root.Version = "{{.SpinVer}}"
	return root
}
