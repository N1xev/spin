
package cmd

import (
	"fmt"

	"github.com/spf13/cobra"
{{- if hasLipgloss .}}

	"{{.Module}}/internal/ui"
{{- end}}
)

var helloCmd = &cobra.Command{
	Use:   "hello [name]",
	Short: "Print a greeting",
	Args:  cobra.MinimumNArgs(1),
	RunE: func(cmd *cobra.Command, args []string) error {
{{- if hasLipgloss .}}
		styles := ui.NewStyles(80)
		greeting := styles.Header.Render(fmt.Sprintf("Hello, %s!", args[0]))
		fmt.Fprintln(cmd.OutOrStdout(), greeting)
{{- else}}
		fmt.Fprintf(cmd.OutOrStdout(), "Hello, %s!\n", args[0])
{{- end}}
		return nil
	},
}
