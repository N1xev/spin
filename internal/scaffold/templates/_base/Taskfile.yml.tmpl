# Taskfile.yml — generated by spin {{.SpinVer}}
# Docs: https://taskfile.dev

version: '3'

vars:
  NAME: '{{.Name}}'

env:
  CGO_ENABLED: '0'

tasks:
  default:
    desc: Build the project
    cmds:
      - task: build

  setup:
    desc: Install gofumpt, goimports, air, and prism
    cmds:
      - go install mvdan.cc/gofumpt@latest
      - go install golang.org/x/tools/cmd/goimports@latest
      - go install github.com/air-verse/air@latest
      - go install go.dalton.dog/prism@latest

  build:
    desc: Build the binary
    cmds:
      - go build -o ./bin/{{.Name}} .

  run:
    desc: Run with hot reload (requires task setup)
    cmds:
      - air

  test:
    desc: Run tests (uses prism if installed, else go test)
    cmds:
      - cmd: |
          if command -v prism >/dev/null 2>&1; then
            prism go test ./...
          else
            go test ./...
          fi

  fmt:
    desc: Format with gofumpt + goimports
    cmds:
      - cmd: |
          if command -v gofumpt >/dev/null 2>&1; then
            gofumpt -l -w .
          else
            gofmt -l -w .
          fi
      - cmd: |
          if command -v goimports >/dev/null 2>&1; then
            goimports -w .
          fi

  vet:
    desc: Run go vet
    cmds:
      - go vet ./...

  clean:
    desc: Remove build artifacts
    cmds:
      - rm -rf ./bin ./tmp
