# .air.toml — generated by spin {{.SpinVer}}
# Docs: https://github.com/air-verse/air
# Note: build.entrypoint is the modern field; the legacy 'bin' key is deprecated.

root = "."
tmp_dir = "tmp"

[build]
  args_bin = []
  cmd = "go build -o ./tmp/main ."
  delay = 1000
  entrypoint = ["./tmp/main"]
  exclude_dir = ["assets", "tmp", "vendor", "node_modules", ".git", "bin"]
  exclude_unchanged = true
  exclude_regex = ["_test\\.go$", ".*_mock\\.go$", ".*\\.generated\\.go$"]
  include_ext = ["go", "tpl", "tmpl", "html", "css", "js", "json", "yaml", "toml", "md", "mod"]
  kill_delay = "0s"
  rerun = false
  rerun_delay = 500

[log]
  level = "info"
  time = true

[misc]
  clean_on_exit = true
