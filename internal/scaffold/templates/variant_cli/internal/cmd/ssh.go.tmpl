//
// ssh subcommand. Starts a wish SSH server on :2222 with bubbletea
// middleware so each SSH connection gets its own bubbletea program.
// Generate the host key with:
//   ssh-keygen -t ed25519 -f .ssh/host_key.pem -N ""
// before running the server.

package cmd

import (
	"context"
	"errors"
	"fmt"
	"os"
	"os/signal"
	"syscall"

	"charm.land/bubbletea/v2"
	"charm.land/wish/v2"
	"charm.land/wish/v2/activeterm"
	wbt "charm.land/wish/v2/bubbletea"
	"charm.land/wish/v2/logging"
	"github.com/charmbracelet/ssh"
	"github.com/spf13/cobra"
)

// teaHandler is the bubbletea model factory for each SSH connection.
// The wish/bubbletea middleware calls this for every new session.
func teaHandler(sess ssh.Session) (tea.Model, []tea.ProgramOption) {
	// A trivial echo model so the connection shows something on
	// connect. Replace with a real bubbletea Model for a real app.
	m := simpleSSHModel{name: sess.User()}
	// bubbletea v2 has no WithAltScreen program option — AltScreen is
	// a field on the tea.View returned by View(). Returning an empty
	// ProgramOption slice gives the default behavior (full screen on
	// connect, the SSH client handles redraw).
	return m, nil
}

type simpleSSHModel struct {
	name string
}

func (m simpleSSHModel) Init() tea.Cmd { return nil }
func (m simpleSSHModel) Update(msg tea.Msg) (tea.Model, tea.Cmd) {
	return m, nil
}
func (m simpleSSHModel) View() tea.View {
	return tea.NewView(fmt.Sprintf("hi from %s — connected via wish!\n", m.name))
}

var sshCmd = &cobra.Command{
	Use:   "ssh",
	Short: "Start a wish SSH server on :2222",
	RunE: func(cmd *cobra.Command, args []string) error {
		hostKeyPath := ".ssh/host_key.pem"
		if _, err := os.Stat(hostKeyPath); err != nil {
			return fmt.Errorf(
				"wish: host key %q not found; run `ssh-keygen -t ed25519 -f %s -N \"\"` first",
				hostKeyPath, hostKeyPath,
			)
		}

		s, err := wish.NewServer(
			wish.WithAddress(":2222"),
			wish.WithHostKeyPath(hostKeyPath),
			wish.WithMiddleware(
				activeterm.Middleware(),
				logging.Middleware(),
				wbt.Middleware(teaHandler),
			),
		)
		if err != nil {
			return err
		}

		ctx, cancel := signal.NotifyContext(context.Background(), syscall.SIGINT, syscall.SIGTERM)
		defer cancel()

		go func() {
			<-ctx.Done()
			_ = s.Shutdown(context.Background())
		}()

		fmt.Fprintln(cmd.ErrOrStderr(), "wish: listening on :2222 (Ctrl-C to stop)")
		if err := s.ListenAndServe(); err != nil && !errors.Is(err, ssh.ErrServerClosed) {
			return err
		}
		return nil
	},
}
