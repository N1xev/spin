// Code generated by spin {{.SpinVer}}. DO NOT EDIT.

package cmd

import (
{{- if hasCobra .}}
	"github.com/spf13/cobra"
{{- end}}
{{- if hasViper .}}
	"{{.Module}}/internal/config"
{{- end}}
)

// RootCmd builds and returns the root cobra command. The hello
// subcommand is always present; ssh is added when --wish.
// viper is wired via PersistentPreRunE when --viper is set.
func RootCmd() *cobra.Command {
	root := &cobra.Command{
		Use:   "{{.Name}}",
		Short: "A {{title .Name}} CLI scaffolded with spin",
		Long: `{{title .Name}} is a charmbracelet v2 CLI application scaffolded with spin.

Built with cobra + fang so the --help and error output render with
charm-style colors, and (optionally) viper for config-file support.`,
{{- if hasViper .}}
		PersistentPreRunE: func(cmd *cobra.Command, args []string) error {
			return config.Bind(cmd.Root())
		},
{{- end}}
		// SilenceUsage on error: fang already prints the usage block
		// when the user runs `--help`; on a runtime error we just
		// want the error line.
		SilenceUsage: true,
	}

	root.AddCommand(helloCmd)
{{- if hasWish .}}
	root.AddCommand(sshCmd)
{{- end}}
{{- if hasViper .}}
	root.PersistentFlags().String("log-level", "info", "log level (debug, info, warn, error)")
{{- end}}

	// fang version metadata is attached via fang.Execute in main.go;
	// the command-level Version is what fang reads for the help/version
	// banners.
	root.Version = "{{.SpinVer}}"
	return root
}
