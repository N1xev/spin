
package ui

import "charm.land/lipgloss/v2"

// Styles is the bundle of lipgloss v2 styles used by CLI subcommands.
// Construct via NewStyles(width) — width is currently unused but the
// signature leaves room for width-dependent styles without churning
// callers when those land.
type Styles struct {
	Header  lipgloss.Style
	Success lipgloss.Style
	Error   lipgloss.Style
}

// NewStyles returns a fresh Styles tuned for the given terminal width.
func NewStyles(width int) Styles {
	header := lipgloss.NewStyle().
		Bold(true).
		Foreground(lipgloss.Color("#FAFAFA")).
		Background(lipgloss.Color("#7D56F4")).
		Padding(0, 1)

	success := lipgloss.NewStyle().
		Bold(true).
		Foreground(lipgloss.Color("#04B575"))

	errStyle := lipgloss.NewStyle().
		Bold(true).
		Foreground(lipgloss.Color("#FF5F87"))

	_ = width
	return Styles{Header: header, Success: success, Error: errStyle}
}
