// Code generated by spin {{.SpinVer}}
// Regenerate with: spin update {{.Name}}

// Thin entry point. All cobra subcommands live in internal/cmd/.
// This file just configures logging (when --log) and hands control
// to fang.Execute(rootCmd) for the charmbracelet-styled help, errors,
// and completions.
package main

import (
	"context"
{{- if hasFang .}}
	"charm.land/fang/v2"
{{- end}}
{{- if not (hasLog .)}}
	"fmt"
{{- end}}
	"os"

{{- if hasLog .}}
	"charm.land/log/v2"
{{- end}}

	"{{.Module}}/internal/cmd"
)

func main() {
{{- if hasLog .}}
	logger := log.New(os.Stderr)
	log.SetDefault(logger)
	log.SetLevel(log.InfoLevel)
{{- end}}
	if err := fang.Execute(context.Background(), cmd.RootCmd(),
		fang.WithVersion("{{.SpinVer}}"),
	); err != nil {
{{- if hasLog .}}
		log.Error("command failed", "err", err)
{{- else}}
		fmt.Fprintln(os.Stderr, err)
{{- end}}
		os.Exit(1)
	}
}
